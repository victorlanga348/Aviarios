// Configuração básica do Prisma 6
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Usuário (Acesso ao sistema)
model User {
  id            String          @id @default(uuid())
  name          String
  email         String          @unique
  password      String
  batches       Batch[]
  customers     Customer[]
  sales         Sale[]
  fixedExpenses FixedExpense[]
  configuration Configuration?
}

// 2. Lote (O Ônibus/Gaveta - Representa cada compra de aves)
model Batch {
  id              String         @id @default(uuid())
  name            String         // Ex: "Lote de Janeiro - Linhagem Cobb"
  startDate       DateTime       @default(now())
  initialQuantity Int            // Quantidade inicial de aves
  actualQuantity  Int?           // Quantidade atual de aves
  costPerBird     Float          // Preço pago por cada ave pequena
  transportCost   Float          @default(0) // Custo de transporte do lote
  status          BatchStatus    @default(ACTIVE) // ACTIVE ou CLOSED
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Relações
  expenses        BatchExpense[] // Custos de Ração e Vacina deste lote
  losses          Loss[]         // Registros de mortes deste lote
  sales           Sale[]         // Vendas vindas deste lote

  @@index([status])
  @@index([startDate])
  @@index([userId])
}

enum BatchStatus {
  ACTIVE
  CLOSED
}

// 3. Custos do Lote (A Mochila do ônibus - Ração e Vacinas extras)
model BatchExpense {
  id          String   @id @default(uuid())
  batchId     String
  type        String   // "RACAO" ou "VACINA"
  description String?
  amount      Float    // Valor gasto
  quantity    Float?   // Opcional: ex: "10 sacos"
  createdAt   DateTime @default(now())

  batch       Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

// 4. Perdas (Mortalidade)
model Loss {
  id        String   @id @default(uuid())
  batchId   String
  quantity  Int
  reason    String?
  date      DateTime @default(now())

  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

// 5. Clientes (O Caderninho de nomes)
model Customer {
  id     String @id @default(uuid())
  name   String
  phone  String?
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sales  Sale[]

  @@index([userId])
}

// 6. Vendas (O Registro da transação)
model Sale {
  id           String    @id @default(uuid())
  batchId      String
  customerId   String
  quantity     Int
  unitPrice    Float
  totalValue   Float     // quantidade * unitPrice
  date         DateTime  @default(now())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Dinheiro pago
  amountPaid   Float     @default(0)
  // Dinheiro que falta pagar
  balance      Float     @default(0)

  status       PaymentStatus @default(PENDENTE)

  // Relações
  batch        Batch     @relation(fields: [batchId], references: [id])
  customer     Customer  @relation(fields: [customerId], references: [id])
  payments     Payment[] // Para controlar dívidas e pagamentos parciais

  @@index([date])
  @@index([customerId])
  @@index([userId])
}

// 7. Pagamentos (Para controlar o "Fiado")
model Payment {
  id          String   @id @default(uuid())
  saleId      String
  amount      Float    // Quanto o cliente pagou nesta vez
  paymentType PaymentType @default(DINHEIRO)
  date        DateTime @default(now())

  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

enum PaymentType {
  DINHEIRO
  TRANSFERENCIA
  CARTAO
}

enum PaymentStatus {
  PENDENTE
  PAGO
  PARCIALMENTE_PAGO
}

// 8. Despesas Fixas (A Gaveta da Casa - Luz, Água)
model FixedExpense {
  id          String   @id @default(uuid())
  description String   // Ex: "Conta de Luz"
  amount      Float
  date        DateTime @default(now()) // O mês será extraído daqui
  userId      String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([userId])
}

// 10. Configurações Globais (Preços, taxas, etc)
model Configuration {
  id                String   @id // O id será o userId do usuário correspondente
  birdSellingPrice  Float    @default(0)
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [id], references: [id], onDelete: Cascade)
}
